FROM pytorch/pytorch:2.5.0-cuda12.4-cudnn9-runtime

WORKDIR /app

# Устанавливаем только необходимые системные зависимости
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /var/cache/apt/*

# Создаем директорию для кеша моделей
RUN mkdir -p /app/models

# Копируем файлы зависимостей
COPY requirements.txt .

# Используем PyTorch из базового образа.
# Это значительно ускоряет и стабилизирует сборку в нестабильных сетях.
ARG PIP_EXTRA_INDEX_URL=https://pypi.org/simple
ARG PIP_TIMEOUT=120
ARG PIP_RETRIES=10
RUN python -c "import torch, torchaudio, torchvision; print(torch.__version__)"

# Оптимизированная установка Python зависимостей.
# Пин toolchain для совместимости сборки openai-whisper (pkg_resources через setuptools).
RUN python -m pip install --no-cache-dir --isolated "pip<26" "setuptools<81" wheel \
        --index-url ${PIP_EXTRA_INDEX_URL} \
        --timeout ${PIP_TIMEOUT} --retries ${PIP_RETRIES} && \
    python -m pip install --no-cache-dir --isolated --no-build-isolation -r requirements.txt \
        --index-url ${PIP_EXTRA_INDEX_URL} \
        --timeout ${PIP_TIMEOUT} --retries ${PIP_RETRIES} && \
    python -m pip cache purge

# Копируем исходный код
COPY app.py .

# Настраиваем переменные окружения
ENV WHISPER_CACHE=/app/models
ENV TORCH_HOME=/app/models
ENV HF_HOME=/app/models
ENV CUDA_VISIBLE_DEVICES=0

# Открываем порт
EXPOSE 8004

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8004/health || exit 1

# Запуск приложения
CMD ["python", "app.py"] 